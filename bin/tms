#!/usr/bin/env zsh
# tms — pick or create a tmux session for a git worktree.
#
# One session per worktree. Repos live in ~/projects/<repo>; feature worktrees
# live in ~/worktrees/<repo>/<branch>. Worktrees are enumerated via
# `git worktree list --porcelain` (source of truth), not by scanning disk.

emulate -L zsh
setopt extended_glob no_aliases

PROJECTS_ROOT="${HOME}/projects"
WORKTREES_ROOT="${HOME}/worktrees"

# Absolute path to this script — used to re-invoke ourselves from inside fzf
# bindings (e.g. tab completion). `:A` resolves with symlinks when invoked
# via a path; otherwise fall back to PATH lookup.
if [[ "$0" == */* ]]; then
    SCRIPT=${0:A}
else
    SCRIPT=$(whence -p "$0" 2>/dev/null || print -- "$0")
fi

die() { print -u2 -- "tms: $*"; exit 1; }

# --- tmux session lookup -----------------------------------------------------

typeset -gA SESSIONS  # name -> "attached" | "detached"

load_sessions() {
    SESSIONS=()
    local line name attached
    while IFS=: read -r name attached; do
        [[ -z "$name" ]] && continue
        if [[ "$attached" -gt 0 ]]; then
            SESSIONS[$name]="attached"
        else
            SESSIONS[$name]="detached"
        fi
    done < <(tmux list-sessions -F '#S:#{session_attached}' 2>/dev/null)
}

session_exists() {
    tmux list-sessions -F '#S' 2>/dev/null | grep -Fxq -- "$1"
}

# --- worktree discovery ------------------------------------------------------

# Emit "id\tpath" lines for one repo: existing worktrees plus every local
# branch that doesn't yet have a worktree (as a creation candidate). Session
# state is overlaid later in format_rows so this output can be cached.
# Run as a background job per repo; writes are line-sized so concurrent
# subshell output interleaves safely (< PIPE_BUF).
discover_one() {
    local repo_dir=$1
    local repo_name=${repo_dir:t}
    local -A seen_branches  # branches already emitted (worktree, local, or remote)
    local wt_path="" branch="" line=""

    # Fork both git invocations up front so they run concurrently. Output is
    # buffered in the pipe (well under 64KB) so neither writer blocks while
    # we drain the other. ~halves slowest-repo latency on a multi-core box.
    local wt_fd refs_fd
    exec {wt_fd}< <({ git -C "$repo_dir" worktree list --porcelain 2>/dev/null; print -- ""; })
    exec {refs_fd}< <(git -C "$repo_dir" for-each-ref --format='%(refname)' refs/heads/ refs/remotes/origin/ 2>/dev/null)

    # Step 1: existing worktrees. seen_branches survives the loop because
    # we use read -u on an already-open FD rather than pipe-to-while.
    while IFS= read -u $wt_fd -r line; do
        if [[ -z "$line" ]]; then
            if [[ -n "$wt_path" ]]; then
                emit_entry "$repo_name" "$wt_path" "$branch" "$repo_dir"
                [[ -n "$branch" ]] && seen_branches[$branch]=1
            fi
            wt_path=""; branch=""
        elif [[ "$line" == "worktree "* ]]; then
            wt_path=${line#worktree }
        elif [[ "$line" == "branch refs/heads/"* ]]; then
            branch=${line#branch refs/heads/}
        fi
    done
    exec {wt_fd}<&-

    # Steps 2+3: local branch candidates, then remote-only branch candidates
    # from origin (create_worktree will base a new local branch on
    # origin/<branch> when one is picked). Parse the full refname to
    # distinguish heads vs remotes/origin and dedupe against seen_branches.
    local ref br id wt_candidate
    while IFS= read -u $refs_fd -r ref; do
        if [[ "$ref" == refs/heads/* ]]; then
            br=${ref#refs/heads/}
        elif [[ "$ref" == refs/remotes/origin/* ]]; then
            br=${ref#refs/remotes/origin/}
            [[ "$br" == HEAD ]] && continue
        else
            continue
        fi
        [[ -n "${seen_branches[$br]:-}" ]] && continue
        seen_branches[$br]=1
        id="${repo_name}/${br}"
        wt_candidate="${WORKTREES_ROOT}/${repo_name}/${br}"
        print -- "${id}\t${wt_candidate}"
    done
    exec {refs_fd}<&-
}

# Fan out one git invocation per repo in parallel. Drops total cost from
# ~O(N*git_fork) to ~O(git_fork) on a multi-core box.
discover() {
    local repo_dir
    for repo_dir in "$PROJECTS_ROOT"/*(N/); do
        # .git as a directory => main checkout. .git as a file => linked
        # worktree of some other repo; skip so we don't double-iterate.
        [[ -d "$repo_dir/.git" ]] || continue
        discover_one "$repo_dir" &
    done
    wait
}

# Emit one worktree entry. Supported layouts:
#   - main checkout: wt_path == ~/projects/<repo>           => id = <repo>
#   - tms worktree:  wt_path under ~/worktrees/<repo>/      => id = <repo>/<branch>
#   - sibling worktree in ~/projects/ (e.g. legacy layout)  => id = <repo>/<branch>
# Anything else is skipped.
emit_entry() {
    local repo_name=$1 wt_path=$2 branch=$3 repo_dir=$4 id
    if [[ "$wt_path" == "$repo_dir" ]]; then
        id="$repo_name"
    elif [[ "$wt_path" == "$WORKTREES_ROOT/$repo_name/"* ]]; then
        if [[ -n "$branch" ]]; then
            id="$repo_name/$branch"
        else
            id="$repo_name/${wt_path#$WORKTREES_ROOT/$repo_name/}"
        fi
    elif [[ "$wt_path" == "$PROJECTS_ROOT/"* && -n "$branch" ]]; then
        id="$repo_name/$branch"
    else
        return 0
    fi
    print -- "${id}\t${wt_path}"
}

# --- cache -------------------------------------------------------------------

CACHE_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/tms/discover.tsv"

# True iff the cache file exists and is newer than every input that can
# change discover's output. We stat the things git actually touches when
# branches/worktrees change: refs/heads, refs/remotes/origin, packed-refs
# (post-fetch + post-pack), and the worktrees subdir. ~60 in-process stats
# via zsh/stat, no forks.
cache_fresh() {
    [[ -f "$CACHE_FILE" ]] || return 1
    zmodload -F zsh/stat b:zstat 2>/dev/null || return 1
    local -a st
    zstat -A st +mtime -- "$CACHE_FILE" 2>/dev/null || return 1
    local cache_mt=$st[1]

    local -a inputs
    local repo_dir f
    inputs=( "$PROJECTS_ROOT" )
    for repo_dir in "$PROJECTS_ROOT"/*(N/); do
        [[ -d "$repo_dir/.git" ]] || continue
        inputs+=(
            "$repo_dir/.git/refs/heads"
            "$repo_dir/.git/refs/remotes/origin"
            "$repo_dir/.git/packed-refs"
            "$repo_dir/.git/worktrees"
        )
    done

    for f in "${inputs[@]}"; do
        [[ -e "$f" ]] || continue
        zstat -A st +mtime -- "$f" 2>/dev/null || continue
        (( st[1] > cache_mt )) && return 1
    done
    return 0
}

bust_cache() { rm -f -- "$CACHE_FILE" 2>/dev/null }

# discover_cached — emit "id\twt_path" lines, served from cache when the
# cache is newer than any git state that affects discover output.
# Atomic write via tmp+rename; concurrent invocations are safe.
discover_cached() {
    if cache_fresh; then
        cat -- "$CACHE_FILE"
        return 0
    fi
    local out
    out=$(discover) || return 1
    mkdir -p -- "${CACHE_FILE:h}" 2>/dev/null
    local tmp="${CACHE_FILE}.$$"
    print -r -- "$out" > "$tmp" && mv -f -- "$tmp" "$CACHE_FILE"
    print -r -- "$out"
}

# --- picker ------------------------------------------------------------------

# Read "id\twt_path" lines on stdin, look up session state from the global
# $SESSIONS map, and emit fzf rows of "display\tid\twt_path" with attached
# sessions sorted first. Single awk pass — the per-row zsh while-read loop
# was ~30 ms for 700+ rows; awk does the same work in ~5 ms.
# Sessions are smuggled in via env var, US/RS-separated to avoid clashes
# with any character a tmux session name could contain.
format_rows() {
    local payload="" k
    for k in "${(@k)SESSIONS}"; do
        payload+="${k}"$'\x1e'"${SESSIONS[$k]}"$'\x1f'
    done
    SESSIONS_STR="$payload" awk -F'\t' '
BEGIN {
    n = split(ENVIRON["SESSIONS_STR"], a, "\x1f")
    for (i = 1; i <= n; i++) {
        p = index(a[i], "\x1e")
        if (p > 0) S[substr(a[i], 1, p-1)] = substr(a[i], p+1)
    }
    HOME = ENVIRON["HOME"] "/"; HOME_LEN = length(HOME)
    PROJ = "~/projects/"; PROJ_LEN = length(PROJ)
    WT   = "~/worktrees/"; WT_LEN  = length(WT)
}
{
    if ($1 == "") next
    dp = $2
    if (substr(dp, 1, HOME_LEN) == HOME) dp = "~/" substr(dp, HOME_LEN + 1)
    st = ($1 in S) ? S[$1] : "none"
    if      (st == "attached") { pri = 0; mk = "●"; c = "\033[1;32m"; r = "\033[0m" }
    else if (st == "detached") { pri = 1; mk = "○"; c = "\033[32m";   r = "\033[0m" }
    else                       { pri = 2; mk = "◌"; c = "";           r = ""        }
    if (substr(dp, 1, PROJ_LEN) == PROJ)
        rendered = sprintf("%-9s %s%s%s", "projects", c, substr(dp, PROJ_LEN + 1), r)
    else if (substr(dp, 1, WT_LEN) == WT)
        rendered = sprintf("%-9s %s%s%s", "worktrees", c, substr(dp, WT_LEN + 1), r)
    else
        rendered = dp
    printf "%d\t%s%s%s %s\t%s\t%s\n", pri, c, mk, r, rendered, $1, $2
}
' | sort -t$'\t' -k1,1n -k3 | cut -d$'\t' -f2-
}

# Build "display\tid\tpath" lines and run fzf.
# Output: query\n key\n selected_row (any may be empty).
#
# Ordering: open sessions stay pinned above everything while you type, but rows
# within each band are still ranked by query relevance. fzf can't do both at
# once — its relevance sort flattens the banding — so we keep --no-sort (fzf
# shows our exact order) and re-rank ourselves on every keystroke via
# change:reload → `$SCRIPT --rank`, which ranks each band (attached, detached,
# none) by relevance and concatenates them back in priority order.
run_picker() {
    local header_extra=$1
    local rows header
    rows=$(discover_cached | format_rows)

    # Snapshot the formatted rows so the per-keystroke re-ranker reads them
    # without re-running discover or tmux.
    local rows_file="${CACHE_FILE:h}/picker.$$"
    mkdir -p -- "${rows_file:h}" 2>/dev/null
    print -r -- "$rows" > "$rows_file"

    header='enter: open highlighted  •  alt-enter: create <repo>/<branch> from query'
    [[ -n "$header_extra" ]] && header="${header_extra}"$'\n'"${header}"

    print -r -- "$rows" | fzf \
        --ansi \
        --with-nth=1 \
        --delimiter=$'\t' \
        --print-query \
        --expect=enter,alt-enter \
        --no-multi \
        --cycle \
        --no-sort \
        --bind "tab:transform-query($SCRIPT --complete {q})" \
        --bind "change:reload($SCRIPT --rank {q} $rows_file)+first" \
        --prompt='tms> ' \
        --header="$header" \
        --layout=reverse
    local st=$?
    rm -f -- "$rows_file"
    return $st
}

# --- input handling ----------------------------------------------------------

create_worktree() {
    local repo=$1 branch=$2
    local repo_dir="$PROJECTS_ROOT/$repo"
    local wt_path="$WORKTREES_ROOT/$repo/$branch"
    local -a git_cmd
    if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
        git_cmd=(git -C "$repo_dir" worktree add "$wt_path" "$branch")
    elif git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
        git_cmd=(git -C "$repo_dir" worktree add -b "$branch" "$wt_path" "origin/$branch")
    else
        git_cmd=(git -C "$repo_dir" worktree add -b "$branch" "$wt_path")
    fi

    "${git_cmd[@]}" >/dev/null 2>&1 || return 1
    print -r -- "$wt_path"
}

# Ensure a usable worktree exists for $repo/$branch. Three cases:
#   1. Folder present — print it and return 0.
#   2. git has the worktree registered but the folder is gone (user rm'd
#      it). Prompt; on yes, prune + recreate; on no, return 2.
#   3. Nothing registered — git worktree add. Return 1 on failure.
# Stdout (on success): the path of the resulting worktree. Recreation
# always lands at the canonical tms path, which may differ from $wt_path.
ensure_worktree() {
    local repo=$1 branch=$2 wt_path=$3
    local repo_dir="$PROJECTS_ROOT/$repo"

    if [[ -d "$wt_path" ]]; then
        print -r -- "$wt_path"
        return 0
    fi

    # Porcelain emits one `worktree <abs-path>` line per entry, so a
    # fixed-string whole-line match tells us whether git still thinks this
    # path is a live worktree.
    if git -C "$repo_dir" worktree list --porcelain 2>/dev/null \
            | grep -Fxq "worktree $wt_path"; then
        local display=${wt_path/#$HOME/\~}
        # Use fzf for the confirmation rather than a raw prompt — running
        # inside a tmux popup, hand-rolled prints to stderr leave residue
        # that the next fzf invocation restores from its alt-buffer.
        local choice
        choice=$(printf 'no — return to picker\nyes — prune and recreate\n' \
            | fzf \
                --header="worktree '$display' is missing" \
                --prompt='recreate? ' \
                --layout=reverse \
                --no-multi)
        [[ "$choice" == yes* ]] || return 2
        git -C "$repo_dir" worktree prune >/dev/null 2>&1
        bust_cache  # prune changed worktree registration; refs/worktrees mtime may not catch it
    fi

    local new_path
    new_path=$(create_worktree "$repo" "$branch") || return 1
    bust_cache  # new worktree directory → next picker must rediscover
    print -r -- "$new_path"
}

# --- session lifecycle -------------------------------------------------------

ensure_session() {
    local name=$1 wt_path=$2
    if session_exists "$name"; then
        return 0
    fi
    tmux new-session  -d -s "$name" -c "$wt_path" -n nvim   || return 1
    tmux send-keys    -t "${name}:nvim" 'nvim' Enter
    tmux new-window   -t "${name}:" -c "$wt_path" -n term
    tmux new-window   -t "${name}:" -c "$wt_path" -n claude
    tmux send-keys    -t "${name}:claude" 'claude' Enter
    tmux select-window -t "${name}:term"
}

enter_session() {
    local name=$1
    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$name"
    else
        tmux attach -t "$name"
    fi
}

# --- main --------------------------------------------------------------------

main() {
    command -v tmux >/dev/null || die "tmux not found"
    command -v git  >/dev/null || die "git not found"
    command -v fzf  >/dev/null || die "fzf not found"
    [[ -d "$PROJECTS_ROOT" ]]  || die "$PROJECTS_ROOT does not exist"

    load_sessions

    local id wt_path header_msg=""
    while true; do
        # Every name gets an `=` — bare `local foo` in zsh prints the current
        # value on re-entry through the loop, which flashes onto the terminal
        # between fzf invocations.
        local picker_out=""
        picker_out=$(run_picker "$header_msg")

        local query="" key="" selected="" rest=""
        query=${picker_out%%$'\n'*}
        rest=${picker_out#*$'\n'}
        key=${rest%%$'\n'*}
        if [[ "$rest" == *$'\n'* ]]; then
            selected=${rest#*$'\n'}
        else
            selected=""
        fi

        # Cancellation: Esc / Ctrl-C => key is empty.
        [[ "$key" != "enter" && "$key" != "alt-enter" ]] && exit 0

        # enter: open the highlighted row when present. alt-enter forces
        # creation from the query — needed when fzf is still fuzzy-matching a
        # similarly-named entry and would otherwise hijack a new-worktree
        # request.
        if [[ "$key" == "enter" && -n "$selected" ]]; then
            # Row format: <display>\t<id>\t<wt_path>
            local sel_rest=${selected#*$'\t'}
            id=${sel_rest%%$'\t'*}
            wt_path=${sel_rest#*$'\t'}
            if [[ -d "$wt_path" ]]; then
                break
            fi
            # Main checkout missing — out of scope for tms recovery.
            if [[ "$id" != */* ]]; then
                header_msg="✗ '$id' is missing — restore it manually"
                continue
            fi
            local sel_repo=${id%%/*} sel_branch=${id#*/}
            local new_path=""
            new_path=$(ensure_worktree "$sel_repo" "$sel_branch" "$wt_path")
            case $? in
                0) wt_path=$new_path; break ;;
                2) header_msg="(skipped recreating $id)"; continue ;;
                *) header_msg="✗ worktree creation aborted or failed"; continue ;;
            esac
        fi

        # alt-enter, or enter with no highlighted row — resolve from the query.
        local typed=$query
        [[ -z "$typed" ]] && exit 0

        if [[ "$typed" != */* ]]; then
            if [[ -e "$PROJECTS_ROOT/$typed/.git" ]]; then
                id=$typed
                wt_path="$PROJECTS_ROOT/$typed"
                break
            fi
            header_msg="✗ '$typed' is not a known repo. Use <repo>/<branch>."
            continue
        fi

        local repo=${typed%%/*}
        local branch=${typed#*/}
        if [[ ! -e "$PROJECTS_ROOT/$repo/.git" ]]; then
            header_msg="✗ repo '$repo' not found in ~/projects"
            continue
        fi

        # Resolve to the registered path if discover knows this id;
        # otherwise fall back to the canonical tms path so ensure_worktree
        # has something to check / create at.
        local candidate=""
        candidate=$(discover_cached | awk -F'\t' -v id="$typed" '$1==id{print $2; exit}')
        [[ -z "$candidate" ]] && candidate="$WORKTREES_ROOT/$repo/$branch"

        local new_path=""
        new_path=$(ensure_worktree "$repo" "$branch" "$candidate")
        case $? in
            0) id=$typed; wt_path=$new_path; break ;;
            2) header_msg="(skipped recreating $typed)"; continue ;;
            *) header_msg="✗ worktree creation aborted or failed"; continue ;;
        esac
    done

    ensure_session "$id" "$wt_path" || die "failed to create session '$id'"
    enter_session  "$id"
}

# Only run main when executed directly. Sourced from bin/tms-bench, this
# guard lets the helpers be reused without firing the picker.
if [[ "$ZSH_EVAL_CONTEXT" == toplevel ]]; then
    # Extend the query to the longest common prefix of every id starting
    # with {q}, like zsh's cd-completion. Wired up via
    # `tab:transform-query(...)` so each tab press grows the query as far
    # as it can without ambiguity. Prefix-only (not fuzzy) — fuzzy LCP
    # doesn't give "fill the safe bit". Reads from `discover_cached` so
    # the worktree list is already warm.
    # Re-rank rows for the live picker (bound to change:reload). Open sessions
    # stay banded on top — attached, then detached, then none — but each band
    # is ranked by query relevance via `fzf --filter` so the best matches
    # surface within the band instead of sinking under input order. Empty query
    # => the pre-sorted file as-is. Marks (●/○/◌) come from format_rows and
    # never occur in paths, so they're a safe band delimiter.
    if [[ "${1:-}" == "--rank" ]]; then
        q=${2:-}; rows_file=${3:-}
        [[ -r "$rows_file" ]] || exit 0
        if [[ -z "$q" ]]; then
            cat -- "$rows_file"
            exit 0
        fi
        grep -F  '●' -- "$rows_file"                 | fzf --filter="$q" --nth=2 --delimiter=$'\t'
        grep -F  '○' -- "$rows_file"                 | fzf --filter="$q" --nth=2 --delimiter=$'\t'
        grep -vF '●' -- "$rows_file" | grep -vF '○'  | fzf --filter="$q" --nth=2 --delimiter=$'\t'
        exit 0
    fi

    if [[ "${1:-}" == "--complete" ]]; then
        q=${2:-}
        discover_cached | awk -F'\t' -v q="$q" '
            { id = $1 }
            substr(id, 1, length(q)) != q { next }
            n == 0 { lcp = id; n = 1; next }
            {
                ml = length(lcp); il = length(id); m = (ml < il) ? ml : il
                i = 1
                while (i <= m && substr(lcp, i, 1) == substr(id, i, 1)) i++
                lcp = substr(lcp, 1, i-1)
                n++
            }
            END { print (n == 0 ? q : lcp) }
        '
        exit 0
    fi

    main "$@"
fi
